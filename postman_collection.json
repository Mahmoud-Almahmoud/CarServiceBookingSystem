{
  "info": {
    "name": "Car Service Booking System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "carId",
      "value": "1"
    },
    {
      "key": "serviceId",
      "value": "1"
    },
    {
      "key": "bookingId",
      "value": "1"
    },
    {
      "key": "carTrimId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "emailConfirmationToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"phoneNumber\": \"0500000000\",\n  \"password\": \"Test123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/refresh-token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Confirm Email",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/confirm-email?userId={{userId}}&token={{emailConfirmationToken}}"
          }
        },
        {
          "name": "Resend Email Confirmation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/resend-email-confirmation",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"token\": \"PASTE_TOKEN_HERE\",\n  \"newPassword\": \"NewPass123!\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"OldPass123!\",\n  \"newPassword\": \"NewPass123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/profile/me"
          }
        }
      ]
    },
    {
      "name": "Car Lookups",
      "item": [
        {
          "name": "Get Brands",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/car-lookups/brands"
          }
        },
        {
          "name": "Get Models By Brand",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/car-lookups/models/1"
          }
        },
        {
          "name": "Get Years By Model",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/car-lookups/years/1"
          }
        },
        {
          "name": "Get Trims By Year",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/car-lookups/trims/1"
          }
        }
      ]
    },
    {
      "name": "Cars",
      "item": [
        {
          "name": "Add Car",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/cars",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carTrimId\": {{carTrimId}},\n  \"plateNumber\": \"12345 AD\"\n}"
            }
          }
        },
        {
          "name": "Get My Cars",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/cars/my-cars"
          }
        },
        {
          "name": "Update Car",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/cars/{{carId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carTrimId\": {{carTrimId}},\n  \"plateNumber\": \"98765 AD\"\n}"
            }
          }
        },
        {
          "name": "Delete Car",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/cars/{{carId}}"
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Get Services",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/services?pageNumber=1&pageSize=10"
          }
        },
        {
          "name": "Create Service Admin",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/services",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"AC Inspection\",\n  \"price\": 100,\n  \"durationInMinutes\": 40\n}"
            }
          }
        },
        {
          "name": "Update Service Admin",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/services/{{serviceId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Premium AC Inspection\",\n  \"price\": 150,\n  \"durationInMinutes\": 60\n}"
            }
          }
        },
        {
          "name": "Delete Service Admin",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/bookings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carId\": {{carId}},\n  \"serviceId\": {{serviceId}},\n  \"locationType\": 1,\n  \"startDate\": \"2026-12-01T10:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/bookings/my-bookings"
          }
        },
        {
          "name": "Get All Bookings Admin",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/bookings?pageNumber=1&pageSize=10"
          }
        },
        {
          "name": "Update Booking Status Admin",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/bookings/{{bookingId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": 2\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Intent",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/payments/create-intent/{{bookingId}}"
          }
        }
      ]
    }
  ]
}